<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="top.daoha.infrastructure.dao.IGroupBuyActivityDao">

    <resultMap id="dateMap" type="top.daoha.infrastructure.dao.po.GroupBuyActivity">
        <id column="id" property="id"/>
        <id column="activity_id" property="activityId"/>
        <id column="activity_name" property="activityName"/>
        <id column="source" property="source"/>
        <id column="channel" property="channel"/>
        <id column="goods_id" property="goodsId"/>
        <id column="discount_id" property="discountId"/>
        <id column="group_type" property="groupType"/>
        <id column="take_limit_count" property="takeLimitCount"/>
        <id column="target" property="target"/>
        <id column="valid_time" property="validTime"/>
        <id column="status" property="status"/>
        <id column="start_time" property="startTime"/>
        <id column="end_time" property="endTime"/>
        <id column="tag_id" property="tagId"/>
        <id column="tag_scope" property="tagScope"/>
        <id column="create_time" property="createTime"/>
        <id column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryGroupBuyActivityList" resultMap="dateMap">
        select * from group_buy_market.group_buy_activity
    </select>
    <select id="queryValidGroupBuyActivity" parameterType="top.daoha.infrastructure.dao.po.GroupBuyActivity" resultMap="dateMap">
        select id, activity_id,activity_name,discount_id,group_type,
               take_limit_count,target,valid_time,status,start_time,
               end_time,tag_id,tag_scope,create_time
        from group_buy_market.group_buy_activity
        where source = #{source} and channel = #{channel}
        order by id desc
        limit 1
    </select>

</mapper>
